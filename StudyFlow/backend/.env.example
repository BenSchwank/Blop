# Kopiere nach .env und trage echte Werte ein ( .env nicht committen )
# Lokal wird .env beim Start von main.py automatisch geladen (python-dotenv).

# --- Ops/Debug (optional): GET /api/health/share-tables?token=... ---
# BLOP_SHARE_TABLE_DIAG_TOKEN=

# --- Supabase (Render): optional Service-Role nur für signierte Storage-URLs (Video/Podcast-Player) ---
# Wenn signierte URLs fehlschlagen: In Render SUPABASE_SERVICE_ROLE_KEY setzen (Dashboard → Settings → API → service_role).
# SUPABASE_SERVICE_ROLE_KEY=

# --- Bereits für KI nötig ---
GOOGLE_API_KEY=dein-gemini-api-key

# --- Optional: Stock-Fotos in KI-Lernvideos (Pexels API, kostenlos mit Limit) ---
# PEXELS_API_KEY=

# --- Lernvideo: MP4 (Defaults im Code: 854x480, CRF 29, 1M — für Free-Tier) ---
# Höhere Qualität / größere Datei:
# LEARNING_VIDEO_WIDTH=960
# LEARNING_VIDEO_HEIGHT=540
# LEARNING_VIDEO_CRF=25
# LEARNING_VIDEO_MAXRATE=1.6M
# LEARNING_VIDEO_BUFSIZE=3.2M
# Noch kleinere Datei:
# LEARNING_VIDEO_CRF=30
# LEARNING_VIDEO_MAXRATE=800k
# Optional: Ken-Burns / Crossfade (siehe main.py / media_pipeline)
# LEARNING_VIDEO_KEN_BURNS=0
# LEARNING_VIDEO_XFADE=0

# --- SMTP: EIN Versand-Postfach für die ganze App (Betreiber) ---
# Die Mails gehen trotzdem an JEDEN Nutzer an seine in der DB gespeicherte E-Mail (users.email).

BLOP_SMTP_HOST=smtp.gmail.com
BLOP_SMTP_PORT=587
BLOP_SMTP_USER=dein-versand-konto@gmail.com
BLOP_SMTP_PASSWORD=dein-16-stelliges-app-passwort
BLOP_SMTP_FROM=dein-versand-konto@gmail.com

# Öffentliche URL der Next.js-App (ohne Slash am Ende) — Link „Zum Ordner“ in der Mail
BLOP_APP_PUBLIC_URL=https://www.blop-study.com

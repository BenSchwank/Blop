<?xml version="1.0"?>
<!-- Do not set manifest package= here: AGP 8.3+ with android.namespace (build.gradle) rejects it;
     Qt 6.10+ androiddeployqt is fine without it. CI must use Qt 6.10+ (see .github/workflows/android_build.yml).
     Application id / Java package remain com.benschwank.blop via namespace + defaultConfig.applicationId. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:installLocation="auto"
    android:versionCode="-- %%INSERT_VERSION_CODE%% --"
    android:versionName="-- %%INSERT_VERSION_NAME%% --">
    <!-- Keep explicit network permissions for Play AAB/release parity. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- %%INSERT_PERMISSIONS inserts Qt defaults; duplicates are harmless -->
    <!-- %%INSERT_FEATURES -->

    <!-- v3.18.6: Android 11+ (API 30+) Package Visibility. Without an
         explicit <queries> declaration QDesktopServices::openUrl() /
         Intent.ACTION_VIEW cannot resolve any installed browser/custom-tab
         implementation and silently returns false — which is exactly the
         "Anmelden öffnet keinen Browser" symptom reported on v3.18.5.
         We list both http+https VIEW intents AND a Chrome Custom Tabs
         service binding so the system can pick the best handler. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="androidx.browser.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true" />
    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:hardwareAccelerated="true"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher_blop"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true"
        android:allowBackup="true"
        android:fullBackupOnly="false">
        <!-- QtLoader resolves these keys from Application meta-data on some builds. -->
        <meta-data
            android:name="android.app.lib_name"
            android:value="@string/qt_app_lib_name" />
        <meta-data
            android:name="android.app.arguments"
            android:value="@string/qt_app_arguments" />
        <activity
            android:name="com.benschwank.blop.BlopActivity"
            android:theme="@style/BlopTheme"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Google OAuth PKCE deep-link callback. The custom scheme matches
                 the redirect URI configured for the Android OAuth client and
                 used by GoogleAuthManager::startPkceLogin().
                 v3.18.9: BOTH slash variants are accepted to be future-proof
                 against Google switching the canonical format. Google's
                 official docs document the single-slash form
                 (com.example.app:/oauth2redirect), v3.18.8 sent double-slash
                 (com.example.app://oauth2redirect). Listing both <data>
                 elements means the intent filter fires regardless of which
                 the OAuth server echoes back. BlopActivity.forwardOAuthIntent
                 filters only on scheme, so it consumes both URIs identically. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- v3.18.40: Match com.benschwank.blop:/oauth2redirect (single slash) -->
                <data
                    android:scheme="com.benschwank.blop"
                    android:path="/oauth2redirect" />
            </intent-filter>

          <meta-data
                android:name="android.app.lib_name"
                android:value="@string/qt_app_lib_name" />

          <meta-data
                android:name="android.app.arguments"
                android:value="@string/qt_app_arguments" />
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.qtprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/qtprovider_paths"/>
        </provider>
    </application>
</manifest>

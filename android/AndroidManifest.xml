<?xml version="1.0"?>
<!-- package: Qt 6.6 androiddeployqt rejects manifest without it ("Invalid android manifest file").
     AGP still uses namespace/applicationId from build.gradle; duplicate package here is a benign warning. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.benschwank.blop"
    android:installLocation="auto"
    android:versionCode="-- %%INSERT_VERSION_CODE%% --"
    android:versionName="-- %%INSERT_VERSION_NAME%% --">
    <!-- %%INSERT_PERMISSIONS inserts network permissions; avoid duplicates here -->
    <!-- %%INSERT_FEATURES -->
    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true" />
    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:hardwareAccelerated="true"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher_blop"
        android:requestLegacyExternalStorage="true"
        android:allowBackup="true"
        android:fullBackupOnly="false">
        <!-- QtLoader resolves these keys from Application meta-data on some builds. -->
        <meta-data
            android:name="android.app.lib_name"
            android:resource="@string/qt_app_lib_name" />
        <meta-data
            android:name="android.app.arguments"
            android:resource="@string/qt_app_arguments" />
        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:theme="@style/BlopTheme"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustPan"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

          <meta-data
                android:name="android.app.lib_name"
                android:resource="@string/qt_app_lib_name" />

          <meta-data
                android:name="android.app.arguments"
                android:resource="@string/qt_app_arguments" />
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.qtprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/qtprovider_paths"/>
        </provider>
    </application>
</manifest>

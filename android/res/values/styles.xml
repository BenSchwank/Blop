<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Blop Dark Theme: matches the app's dark background color -->
    <style name="BlopTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Status + nav bar painted by the app itself, so we make the
             system overlays transparent and let the Qt window background
             extend behind them. This eliminates the dark "Balkenplatz"
             that used to show above the app on phones with a status bar. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Window background: dark, matches the JNI status-bar tint -->
        <item name="android:windowBackground">#0D0B14</item>
        <!-- Light status bar icons: false = white icons on dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Keep app content eligible for edge-to-edge immersive drawing -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Allow content to render into the cutout / notch area on
             Android 9+. shortEdges fills the top cutout in portrait
             without losing pixels in landscape. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>

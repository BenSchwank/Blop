*~
*.autosave
*.a
*.core
*.moc
*.o
*.obj
*.orig
*.rej
*.so
*.so.*
*_pch.h.cpp
*_resource.rc
*.qm
.#*
*.*#
core
!core/
tags
.DS_Store
.directory
*.debug
Makefile*
*.prl
*.app
moc_*.cpp
ui_*.h
qrc_*.cpp
Thumbs.db
*.res
*.rc
/.qmake.cache
/.qmake.stash

# qtcreator generated files
*.pro.user*
*.qbs.user*
CMakeLists.txt.user*

# xemacs temporary files
*.flc

# Vim temporary files
.*.swp

# Visual Studio generated files
*.ib_pdb_index
*.idb
*.ilk
*.pdb
*.sln
*.suo
*.vcproj
*vcproj.*.*.user
*.ncb
*.sdf
*.opensdf
*.vcxproj
*vcxproj.*

# MinGW generated files
*.Debug
*.Release

# Python byte code
*.pyc

# Python virtualenv (local dev)
.venv/

# Binaries
# --------
*.dll
*.exe

# Directories with generated files
.moc/
.obj/
.pch/
.rcc/
.uic/
/build*/

# Cursor / IDE (tracked: share .cursor config in repo)

# ONNX Runtime binaries (downloaded, not tracked)
externals/onnxruntime/

# ONNX model files (generated via scripts/export_math_ocr_model.py)
assets/models/*.onnx
assets/models/tokens.json

# Stray crash dumps / logs (the previous process used to scatter
# blop_*.txt + crash_*.txt across the repo root)
blop_*.txt
crash_*.txt
*_pid.txt
pkg_dump.txt
installed_dexdump.txt
aqtinstall.log

# Node modules (StudyFlow side ships its own; the root tree should
# never have a node_modules folder again)
node_modules/

# Windows oddities
desktop.ini

# Qt Creator / clangd / qmltypes caches (defensive; /build*/ already
# covers the build dirs themselves)
.qtc_clangd/
.qt/

# Gradle / APK / AAB artifacts
.gradle/
*.apk
*.aab
